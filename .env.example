# Neon PostgreSQL — get from neon.tech (free tier)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# NextAuth — run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="your-random-32-char-secret-here"

# For local dev
NEXTAUTH_URL="http://localhost:3000"
# For production (set this in Vercel dashboard, not here):
# NEXTAUTH_URL="https://your-app.vercel.app"
