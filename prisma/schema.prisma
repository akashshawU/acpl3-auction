generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AuctionType {
  DEMO
  LIVE
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   // SUPER_ADMIN | CAPTAIN
  name      String
  teamId    String?
  team      Team?    @relation(fields: [teamId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs AuditLog[]
}

model Player {
  id       String  @id @default(cuid())
  fullName String  @unique
  nickname String?

  primaryRole  String
  battingStyle String
  bowlingStyle String

  matchesPlayed  Int   @default(0)
  runs           Int   @default(0)
  highestScore   Int   @default(0)
  battingAverage Float @default(0)
  strikeRate     Float @default(0)
  wickets        Int   @default(0)
  bestBowlingFigures String?
  economyRate    Float @default(0)
  catches        Int   @default(0)
  runOuts        Int   @default(0)
  momAwards      Int   @default(0)

  // Contact
  mobileNumber  String?
  whatsappNumber String?

  // Profile extras
  bio                      String?
  strengths                String?
  preferredBattingPosition Int?
  preferredBowlingPhase    String?

  // AI scouting note — hardcoded per player, displayed on live auction screen
  aiRecommendation String?

  status       String @default("APPROVED")
  basePrice    Int    @default(10)
  soldPrice    Int?
  acplRating   Int    @default(0)
  acplCategory String @default("C")
  auctionOrder Int?
  teamId       String?
  team         Team?  @relation(fields: [teamId], references: [id])
  photoUrl     String?

  bids        Bid[]
  auditLogs   AuditLog[]
  performance PlayerPerformance?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([teamId])
}

model PlayerPerformance {
  id       String @id @default(cuid())
  playerId String @unique
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  // Batting
  innings                  Int   @default(0)
  runs                     Int   @default(0)
  battingAverage           Float @default(0)
  strikeRate               Float @default(0)
  rankInBattingLeaderboard Int   @default(0)

  // Bowling
  wickets                  Int   @default(0)
  economy                  Float @default(0)
  bowlingAverage           Float @default(0)
  rankInBowlingLeaderboard Int   @default(0)

  // Fielding / all-round
  dismissal Int @default(0)

  // MVP
  mvpScore             Float @default(0)
  rankInMVPLeaderboard Int   @default(0)

  // Calculated — always system-generated
  cumulativeAuctionScore Float  @default(0)
  casCategory            String @default("C")

  // Admin override
  adminScoreOverride Float?
  overrideReason     String?

  importedAt   DateTime?
  lastEditedBy String?
  lastEditedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Team {
  id             String  @id @default(cuid())
  name           String  @unique
  color          String?
  logoUrl        String?
  purse          Int     @default(100)
  remainingPurse Int     @default(100)

  players Player[]
  users   User[]
  bids    Bid[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuctionSession {
  id                  String      @id @default(cuid())
  name                String      @default("ACPL 3 Player Auction")
  type                AuctionType @default(DEMO)
  status              String      @default("SCHEDULED")
  timerSeconds        Int         @default(30)
  bidIncrement        Int         @default(1)
  currentPlayerId     String?
  currentBid          Int?
  currentLeaderTeamId String?
  timerStartedAt      DateTime?
  isArchived          Boolean     @default(false)
  archivedAt          DateTime?

  bids           Bid[]
  auditLogs      AuditLog[]
  auctionResults AuctionResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuctionResult {
  id          String         @id @default(cuid())
  sessionId   String
  session     AuctionSession @relation(fields: [sessionId], references: [id])
  playerId    String
  playerName  String
  teamId      String
  teamName    String
  soldPrice   Int
  auctionType AuctionType
  createdAt   DateTime       @default(now())

  @@index([sessionId])
}

model Bid {
  id        String         @id @default(cuid())
  sessionId String
  session   AuctionSession @relation(fields: [sessionId], references: [id])
  playerId  String
  player    Player         @relation(fields: [playerId], references: [id])
  teamId    String
  team      Team           @relation(fields: [teamId], references: [id])
  amount    Int
  status    String         @default("WINNING")

  createdAt DateTime @default(now())

  @@index([sessionId, playerId])
}

model AuditLog {
  id        String          @id @default(cuid())
  userId    String?
  user      User?           @relation(fields: [userId], references: [id])
  playerId  String?
  player    Player?         @relation(fields: [playerId], references: [id])
  sessionId String?
  session   AuctionSession? @relation(fields: [sessionId], references: [id])
  action    String
  amount    Int?
  details   Json?
  createdAt DateTime        @default(now())

  @@index([createdAt])
}
