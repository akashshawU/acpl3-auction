generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   // SUPER_ADMIN | CAPTAIN
  name      String
  teamId    String?
  team      Team?    @relation(fields: [teamId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs AuditLog[]
}

model Player {
  id       String  @id @default(cuid())
  fullName String  @unique
  nickname String?

  primaryRole  String
  battingStyle String
  bowlingStyle String

  matchesPlayed  Int   @default(0)
  runs           Int   @default(0)
  highestScore   Int   @default(0)
  battingAverage Float @default(0)
  strikeRate     Float @default(0)
  wickets        Int   @default(0)
  bestBowlingFigures String?
  economyRate    Float @default(0)
  catches        Int   @default(0)
  runOuts        Int   @default(0)
  momAwards      Int   @default(0)

  status       String @default("APPROVED")
  basePrice    Int    @default(10)
  soldPrice    Int?
  acplRating   Int    @default(0)
  acplCategory String @default("C")
  auctionOrder Int?
  teamId       String?
  team         Team?  @relation(fields: [teamId], references: [id])
  photoUrl     String?

  bids      Bid[]
  auditLogs AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([teamId])
}

model Team {
  id             String  @id @default(cuid())
  name           String  @unique
  color          String?
  purse          Int     @default(100)
  remainingPurse Int     @default(100)

  players Player[]
  users   User[]
  bids    Bid[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuctionSession {
  id                  String    @id @default(cuid())
  name                String    @default("ACPL 3 Player Auction")
  status              String    @default("SCHEDULED")
  timerSeconds        Int       @default(30)
  bidIncrement        Int       @default(1)
  currentPlayerId     String?
  currentBid          Int?
  currentLeaderTeamId String?
  timerStartedAt      DateTime?

  bids      Bid[]
  auditLogs AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bid {
  id        String         @id @default(cuid())
  sessionId String
  session   AuctionSession @relation(fields: [sessionId], references: [id])
  playerId  String
  player    Player         @relation(fields: [playerId], references: [id])
  teamId    String
  team      Team           @relation(fields: [teamId], references: [id])
  amount    Int
  status    String         @default("WINNING")

  createdAt DateTime @default(now())

  @@index([sessionId, playerId])
}

model AuditLog {
  id        String          @id @default(cuid())
  userId    String?
  user      User?           @relation(fields: [userId], references: [id])
  playerId  String?
  player    Player?         @relation(fields: [playerId], references: [id])
  sessionId String?
  session   AuctionSession? @relation(fields: [sessionId], references: [id])
  action    String
  amount    Int?
  details   Json?
  createdAt DateTime        @default(now())

  @@index([createdAt])
}
